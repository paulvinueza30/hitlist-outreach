{
  "$schema": "https://schemas.tauri.app/config/capability.json",
  "identifier": "default",
  "description": "Default capabilities for Hitlist Outreach",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-delete",
    "store:allow-load",
    "opener:allow-open-url"
  ]
}
